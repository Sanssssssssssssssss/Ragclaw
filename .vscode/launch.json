{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Uvicorn",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/backend",
      "args": [
        "app:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8004",
        "--reload"
      ],
      "jinja": true,
      "envFile": "${workspaceFolder}/backend/.env"
    },
    {
      "name": "Frontend: Next.js",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/frontend"
    },
    {
      "name": "Open Frontend in Edge",
      "type": "pwa-msedge",
      "request": "launch",
      "url": "http://127.0.0.1:3000",
      "webRoot": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "Demo: Backend + Frontend",
      "configurations": [
        "Backend: Uvicorn",
        "Frontend: Next.js"
      ]
    }
  ]
}
